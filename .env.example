  GNU nano 7.2                      .env.example                                
# Инструкция:
# 1. Скопируй этот файл: cp .env.example .env
# 2. Заполни реальные значения в .env
# 3. .env НЕ коммитится в Git! (указан в .gitignore)

# IP адрес или домен
# Пример: SERVER_HOST=192.168.1.1
# Пример: SERVER_HOST=monitoring.example.com
# Локально: SERVER_HOST=localhost
SERVER_HOST=your_server_ip_or_domain

# Проект 
COMPOSE_PROJECT_NAME=webapp

# Nginx 
NGINX_HTTP_PORT=80

# PostgreSQL (только для debug)
POSTGRES_USER=appuser
POSTGRES_DB=appdb
ADMINER_PORT=8080

# Prometheus 
PROMETHEUS_PORT=9090

# Grafana 
GRAFANA_ADMIN_USER=admin
GRAFANA_PORT=3000

# Node Exporter 
NODE_EXPORTER_PORT=9100

# cAdvisor (отладка) 
CADVISOR_PORT=8081

